# ============================================
# CONFIGURATION DU BOT DISCORD
# ============================================
# Copie ce fichier en .env et remplis les valeurs

# Token du bot (depuis https://discord.com/developers/applications)
DISCORD_TOKEN=ton_token_ici

# ID de l'application (depuis https://discord.com/developers/applications > General Information)
CLIENT_ID=id_de_lapplication

# ID de ton serveur Discord (clic droit sur le serveur > Copier l'identifiant)
GUILD_ID=ton_guild_id_ici

# ID du channel où le bot poste les réservations (clic droit sur le channel > Copier l'identifiant)
CHANNEL_RESERVATIONS=id_du_channel_reservations

# ID du channel journal des paiements
CHANNEL_JOURNAL=id_du_channel_journal

# ID du rôle admin (ceux qui peuvent créer des soirées, gérer les abonnements)
ADMIN_ROLE_ID=id_du_role_admin
